# ──────────────────────────────────────────────
# Fitness Bahia Expo 2026 — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Evolution API
EVOLUTION_API_URL=https://evo.yourdomain.com
EVOLUTION_API_KEY=your_global_api_key_here
INSTANCE=your_instance_name

# Follow-up delay in seconds (default: 300 = 5 minutes)
FOLLOWUP_DELAY=300

# Server port (Railway injects this automatically)
PORT=5000
